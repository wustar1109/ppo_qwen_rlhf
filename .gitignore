# =========================
# 1. Python 基础与运行缓存
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# =========================
# 2. 虚拟环境 (核心原则：不提交环境本身)
# =========================
venv/
env/
.venv/
conda_env/

# =========================
# 3. 机器学习专属 (模型权重、检查点)
# =========================
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors
*.h5
*.pb

# =========================
# 4. 训练日志与可视化工具
# =========================
runs/
wandb/
logs/
tensorboard/

# =========================
# 5. 数据集与临时测试输出
# =========================
# 排除整个临时输出目录 (涵盖你之前的 tmp_task_out4 等)
tmp_task_out*/
temp/
out/
tmp/

# 排除 data 目录，但保留里面的 sample_tasks.csv 作为示例，可以这样写：
# data/*
# !data/sample_tasks.csv

# =========================
# 6. IDE、编辑器与系统文件
# =========================
.DS_Store
.idea/
.vscode/
*.swp
*.ipynb_checkpoints/

# =========================
# 7. 环境变量与私密配置 (绝对不要提交！)
# =========================
.env
*.local